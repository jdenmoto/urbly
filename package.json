{
  "name": "urbly-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "npm --prefix functions run build && firebase emulators:start --only auth,functions,firestore,storage,hosting & vite --mode emulator",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -b --pretty false",
    "build": "npm run typecheck && vite build",
    "build:functions": "npm --prefix functions run build",
    "build:minimum": "npm run build && npm run build:functions",
    "validate:release": "npm run lint && npm run build:minimum",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx",
    "lint:ci": "node scripts/lint-changed.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy": "npm run deploy:backend && npm run deploy:frontend",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:backend": "npm --prefix functions run build && firebase deploy --only functions,firestore:rules,firestore:indexes,storage",
    "deploy:frontend": "npm run build && firebase deploy --only hosting",
    "functions:logs": "firebase functions:log",
    "firestore:seed": "node scripts/seed-firestore.mjs",
    "firestore:migrate:default-account": "node scripts/migrate-default-account.mjs",
    "firestore:clear:buildings": "node scripts/clear-buildings.mjs",
    "firestore:clear": "node scripts/clear-firestore.mjs",
    "sync:users": "node scripts/sync-users.mjs",
    "seed:users": "node scripts/seed-demo-users.mjs",
    "seed:all": "npm run firestore:seed && npm run seed:users",
    "seed:smoke": "node scripts/seed-smoke-check.mjs",
    "firestore:re-init": "npm run firestore:clear && npm run firestore:seed",
    "deploy:preview": "PATH=$PATH:/snap/bin node scripts/deploy-preview.mjs",
    "deploy:preview:branch": "PATH=$PATH:/snap/bin node scripts/deploy-preview.mjs",
    "preview:allow-url": "node scripts/add-preview-referrer.mjs",
    "test:rules": "firebase emulators:exec --project demo-urbly-rules --only firestore,storage \"vitest run --environment node src/test/rules/firebaseRules.test.ts\""
  },
  "dependencies": {
    "@fullcalendar/daygrid": "^6.1.11",
    "@fullcalendar/interaction": "^6.1.11",
    "@fullcalendar/list": "^6.1.11",
    "@fullcalendar/multimonth": "^6.1.11",
    "@fullcalendar/react": "^6.1.11",
    "@fullcalendar/timegrid": "^6.1.11",
    "@hookform/resolvers": "^3.3.4",
    "@tanstack/react-query": "^5.59.16",
    "@tanstack/react-table": "^8.20.5",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "festivos-colombianos": "^1.0.6",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "framer-motion": "^12.38.0",
    "js-yaml": "^4.1.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-router-dom": "^6.26.2",
    "read-excel-file": "^9.0.6",
    "recharts": "^2.15.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.11.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "firebase-tools": "^15.18.0",
    "globals": "^15.15.0",
    "jsdom": "^29.1.0",
    "postcss": "^8.5.12",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.1",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@google-cloud/firestore": "^8.5.0",
    "@google-cloud/storage": "^8.5.0",
    "google-gax": "^5.0.6",
    "retry-request": "^8.0.0",
    "teeny-request": "^10.1.2",
    "gaxios": "^7.1.4",
    "uuid": "^14.0.0",
    "protobufjs": "^7.5.5",
    "node-forge": "^1.4.0",
    "path-to-regexp": "^0.1.13",
    "qs": "^6.14.2",
    "rimraf": "^6.1.3",
    "glob": "^13.0.6"
  }
}
