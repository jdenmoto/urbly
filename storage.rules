rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function activeAccountId() {
      return isSignedIn()
        && request.auth.token.keys().hasAny(['activeAccountId'])
        && request.auth.token.activeAccountId is string
        ? request.auth.token.activeAccountId
        : null;
    }

    function isAccountMember(accountId) {
      return isSignedIn()
        && accountId is string
        && firestore.exists(/databases/(default)/documents/accounts/$(accountId)/members/$(request.auth.uid));
    }

    function accountRole(accountId) {
      return isAccountMember(accountId)
        ? firestore.get(/databases/(default)/documents/accounts/$(accountId)/members/$(request.auth.uid)).data.role
        : null;
    }

    function isActiveAccountMember(accountId) {
      return activeAccountId() == accountId && isAccountMember(accountId);
    }

    function serviceOrderExists(serviceOrderId) {
      return serviceOrderId is string
        && firestore.exists(/databases/(default)/documents/service_orders/$(serviceOrderId));
    }

    function serviceOrderData(serviceOrderId) {
      return firestore.get(/databases/(default)/documents/service_orders/$(serviceOrderId)).data;
    }

    function serviceOrderAccountId(serviceOrderId) {
      return serviceOrderExists(serviceOrderId)
        && serviceOrderData(serviceOrderId).keys().hasAny(['accountId'])
        && serviceOrderData(serviceOrderId).accountId is string
        ? serviceOrderData(serviceOrderId).accountId
        : null;
    }

    function isServiceOrderActiveAccount(serviceOrderId) {
      let accountId = serviceOrderAccountId(serviceOrderId);
      return accountId is string && isActiveAccountMember(accountId);
    }

    function isEvidenceReaderRole(memberRole) {
      return memberRole == 'owner'
        || memberRole == 'admin'
        || memberRole == 'editor'
        || memberRole == 'supervisor'
        || memberRole == 'scheduler'
        || memberRole == 'operator'
        || memberRole == 'auditoria';
    }

    function isEvidenceWriterRole(memberRole) {
      return memberRole == 'owner'
        || memberRole == 'admin'
        || memberRole == 'editor'
        || memberRole == 'supervisor'
        || memberRole == 'operator';
    }

    function isAssignedTechnician(serviceOrderId) {
      return isServiceOrderActiveAccount(serviceOrderId)
        && accountRole(serviceOrderAccountId(serviceOrderId)) == 'technician'
        && serviceOrderData(serviceOrderId).keys().hasAny(['assignedTechnicianId'])
        && serviceOrderData(serviceOrderId).assignedTechnicianId == request.auth.uid;
    }

    function canReadServiceOrderEvidence(serviceOrderId) {
      return isServiceOrderActiveAccount(serviceOrderId)
        && (
          isEvidenceReaderRole(accountRole(serviceOrderAccountId(serviceOrderId)))
          || isAssignedTechnician(serviceOrderId)
        );
    }

    function canWriteServiceOrderEvidence(serviceOrderId) {
      return isServiceOrderActiveAccount(serviceOrderId)
        && (
          isEvidenceWriterRole(accountRole(serviceOrderAccountId(serviceOrderId)))
          || isAssignedTechnician(serviceOrderId)
        );
    }

    function isImage() {
      return request.resource != null
        && request.resource.contentType.matches('image/.*');
    }

    function underSizeLimit() {
      // 15MB por imagen
      return request.resource != null
        && request.resource.size < 15 * 1024 * 1024;
    }

    function canUploadEvidence(serviceOrderId) {
      return canWriteServiceOrderEvidence(serviceOrderId) && isImage() && underSizeLimit();
    }

    match /appointments/{appointmentId}/issues/{issueId}/{fileName} {
      allow read, write: if false;
    }

    match /appointments/{appointmentId}/completion-photos/{fileName} {
      allow read, write: if false;
    }

    match /service-orders/{serviceOrderId}/attachments/{fileName} {
      allow read: if canReadServiceOrderEvidence(serviceOrderId);
      allow write: if canUploadEvidence(serviceOrderId);
    }

    match /service-orders/{serviceOrderId}/completion-photos/{fileName} {
      allow read: if canReadServiceOrderEvidence(serviceOrderId);
      allow write: if canUploadEvidence(serviceOrderId);
    }

    match /service-orders/{serviceOrderId}/issues/{issueId}/{fileName} {
      allow read: if canReadServiceOrderEvidence(serviceOrderId);
      allow write: if canUploadEvidence(serviceOrderId);
    }

    match /accounts/{accountId}/service-orders/{serviceOrderId}/attachments/{fileName} {
      allow read: if serviceOrderAccountId(serviceOrderId) == accountId
        && canReadServiceOrderEvidence(serviceOrderId);
      allow write: if serviceOrderAccountId(serviceOrderId) == accountId
        && canUploadEvidence(serviceOrderId);
    }

    match /accounts/{accountId}/service-orders/{serviceOrderId}/completion-photos/{fileName} {
      allow read: if serviceOrderAccountId(serviceOrderId) == accountId
        && canReadServiceOrderEvidence(serviceOrderId);
      allow write: if serviceOrderAccountId(serviceOrderId) == accountId
        && canUploadEvidence(serviceOrderId);
    }

    match /accounts/{accountId}/service-orders/{serviceOrderId}/issues/{issueId}/{fileName} {
      allow read: if serviceOrderAccountId(serviceOrderId) == accountId
        && canReadServiceOrderEvidence(serviceOrderId);
      allow write: if serviceOrderAccountId(serviceOrderId) == accountId
        && canUploadEvidence(serviceOrderId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
